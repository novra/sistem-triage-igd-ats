GEMINI_API_KEY=
HUGGINGFACE_API_KEY=

# Model Mandiri RunPod.
# CUSTOM_MODEL_URL may point to a RunPod serverless runsync endpoint or a vLLM/OpenAI-compatible /v1 endpoint.
CUSTOM_MODEL_URL=
RUNPOD_ENDPOINT_URL=

# Token aliases. RUNPOD_API_KEY is preferred, RUNPOD_VLLM_TOKEN is supported for existing deployments.
RUNPOD_API_KEY=
RUNPOD_VLLM_TOKEN=

# Optional model name for RunPod vLLM/OpenAI-compatible endpoints.
RUNPOD_VLLM_MODEL=triage-qwen3-lora

# Autentikasi & sesi login. JWT_SECRET WAJIB diisi di production (server gagal start jika kosong).
JWT_SECRET=
JWT_EXPIRES_IN=10h

# Bootstrap akun admin pertama — hanya dipakai sekali saat tabel users masih kosong.
ADMIN_EMAIL=
ADMIN_NAME=Administrator
ADMIN_PASSWORD=

# Email transaksional (opsional) via Resend — pembuatan user tetap berhasil walau ini kosong,
# admin cukup memberi tahu password awal secara manual.
RESEND_API_KEY=
EMAIL_FROM=no-reply@example.com
APP_URL=http://localhost:3000
