GEMINI_API_KEY=
HUGGINGFACE_API_KEY=

# Model Mandiri RunPod.
# Untuk worker-vllm RunPod, pakai rute /openai/v1/chat/completions, BUKAN /run atau /runsync mentah:
# hanya rute /openai/ yang meneruskan chat_template_kwargs (mis. enable_thinking:false untuk Qwen3)
# ke vLLM. Lewat /runsync mentah, flag itu diabaikan sehingga model bisa terus "thinking" sampai
# token budget habis sebelum sempat mengeluarkan jawaban JSON.
# Contoh: https://api.runpod.ai/v2/<ENDPOINT_ID>/openai/v1/chat/completions
CUSTOM_MODEL_URL=
RUNPOD_ENDPOINT_URL=

# Token aliases. RUNPOD_API_KEY is preferred, RUNPOD_VLLM_TOKEN is supported for existing deployments.
RUNPOD_API_KEY=
RUNPOD_VLLM_TOKEN=

# Optional model name for RunPod vLLM/OpenAI-compatible endpoints.
RUNPOD_VLLM_MODEL=triage-qwen3-lora

# Autentikasi & sesi login. JWT_SECRET WAJIB diisi di production (server gagal start jika kosong).
JWT_SECRET=
JWT_EXPIRES_IN=10h

# Bootstrap akun admin pertama — hanya dipakai sekali saat tabel users masih kosong.
ADMIN_EMAIL=
ADMIN_NAME=Administrator
ADMIN_PASSWORD=

# Email transaksional (opsional) via Resend — pembuatan user tetap berhasil walau ini kosong,
# admin cukup memberi tahu password awal secara manual.
# Kalau belum verifikasi domain sendiri di Resend (Settings > Domains), pakai EMAIL_FROM
# bawaan sandbox mereka: onboarding@resend.dev. Di mode sandbox, Resend HANYA mau kirim ke
# alamat email yang dipakai daftar akun Resend itu sendiri, bukan ke email user lain manapun
# — untuk kirim ke email siapa saja perlu verifikasi domain sendiri dulu.
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
APP_URL=http://localhost:3000
