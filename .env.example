GEMINI_API_KEY=
HUGGINGFACE_API_KEY=

# Model Mandiri RunPod.
# CUSTOM_MODEL_URL may point to a RunPod serverless runsync endpoint or a vLLM/OpenAI-compatible /v1 endpoint.
CUSTOM_MODEL_URL=
RUNPOD_ENDPOINT_URL=

# Token aliases. RUNPOD_API_KEY is preferred, RUNPOD_VLLM_TOKEN is supported for existing deployments.
RUNPOD_API_KEY=
RUNPOD_VLLM_TOKEN=

# Optional model name for RunPod vLLM/OpenAI-compatible endpoints.
RUNPOD_VLLM_MODEL=triage-qwen3-lora
